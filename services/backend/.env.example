# -----------------------------------------------
# Secret key and token settings
# This is a critical value for security. Generate a strong random string and keep it secret.
# You can generate a secure key using Python:
# import secrets
# print(secrets.token_urlsafe(32))
# The ACCESS_TOKEN_EXPIRE_MINUTES is set to 7 days (10080 minutes) by default, but you can adjust it as needed.
# -----------------------------------------------

SECRET_KEY=<paste your generated value here>
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# -----------------------------------------------
# PostgreSQL
# -----------------------------------------------
POSTGRES_DB=some_db
POSTGRES_USER=some_user
POSTGRES_PASSWORD=some_pass
POSTGRES_HOST=some_host
POSTGRES_PORT=5432

# -----------------------------------------------
# SQLAlchemy / Alembic connection URL
# Written out literally — pydantic-settings does
# not interpolate ${VAR} syntax in .env files.
# -----------------------------------------------
DATABASE_URL=postgresql+psycopg2://_YOUR_USER_:_YOUR_PASSWORD_@pgbouncer:6432/_YOUR_DATABASE_

# -----------------------------------------------
# Uvicorn
# 1 worker is correct for this stack — see README.
# Increase only if you move the scheduler out of
# the backend process first.
# -----------------------------------------------
BACKEND_WORKERS=1
WEB_SERVER_START_PORT=8000