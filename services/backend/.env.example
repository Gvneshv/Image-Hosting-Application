# -----------------------------------------------
# PostgreSQL
# -----------------------------------------------
POSTGRES_DB=some_db
POSTGRES_USER=some_user
POSTGRES_PASSWORD=some_pass
POSTGRES_HOST=some_host
POSTGRES_PORT=5432

# -----------------------------------------------
# SQLAlchemy / Alembic connection URL
# Written out literally — pydantic-settings does
# not interpolate ${VAR} syntax in .env files.
# -----------------------------------------------
DATABASE_URL=postgresql+psycopg2://_YOUR_USER_:_YOUR_PASSWORD_@pgbouncer:6432/_YOUR_DATABASE_

# -----------------------------------------------
# Uvicorn
# 1 worker is correct for this stack — see README.
# Increase only if you move the scheduler out of
# the backend process first.
# -----------------------------------------------
BACKEND_WORKERS=1
WEB_SERVER_START_PORT=8000